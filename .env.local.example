# URL absoluta do backend Spring Boot (BFF server-side)
# DEV local: http://localhost:8080
# PROD recomendado: https://gopro.innovatismc.com/backend-api
API_BASE_URL=http://localhost:8080
API_TIMEOUT_MS=30000
PORT=3001
JWT_SECRET=defina-um-segredo-forte-para-rotas-server-side-do-next

# URL que o browser usa para chamar o BFF do Next.js
NEXT_PUBLIC_API_BASE_URL=/api/backend
NEXT_PUBLIC_API_TIMEOUT_MS=15000

# Limite maximo do valor do projeto no front-end (BRL)
NEXT_PUBLIC_PROJECT_MAX_CONTRACT_VALUE=9999999999999.99
